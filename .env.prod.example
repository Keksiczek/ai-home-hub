# AI Home Hub – Production environment variables
# Copy this file to .env.prod and adjust values.

# Application
APP_PORT=8000
SAFE_MODE=true
TZ=Europe/Prague

# Resource limits
APP_MEMORY_LIMIT=2g
OLLAMA_MEMORY_LIMIT=4g

# Ollama
OLLAMA_PORT=11434

# Grafana (only used when monitoring profile is active)
# Start with: docker compose -f docker-compose.prod.yml --profile monitoring up -d
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=changeme
