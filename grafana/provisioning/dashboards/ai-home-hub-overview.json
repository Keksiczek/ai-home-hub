      "targets": [
        {
          "expr": "job_queue_depth",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Jobs",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 10 },
