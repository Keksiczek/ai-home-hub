{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Resident Agent",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Agent Cycle Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(resident_cycles_total{status=\"success\"}[5m])",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "rate(resident_cycles_total{status=\"fail\"}[5m])",
          "legendFormat": "Fail",
          "refId": "B"
        },
        {
          "expr": "rate(resident_cycles_total{status=\"aborted\"}[5m])",
          "legendFormat": "Aborted",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Agent Queue Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "resident_queue_depth",
          "legendFormat": "Queue",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Safe Mode",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "safe_mode_enabled",
          "legendFormat": "Safe Mode",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "OFF", "color": "red" }, "1": { "text": "ON", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Agent Memory Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "agent_memory_usage_bytes",
          "legendFormat": "Memory",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 104857600 },
              { "color": "red", "value": 524288000 }
            ]
          }
        }
      }
    },
    {
      "title": "Spawn Blocked (by reason)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(agent_spawn_blocked_total[5m])",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "System & Jobs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "title": "Job Queue by Status",
