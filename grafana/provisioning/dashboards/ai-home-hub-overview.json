    {
      "title": "Ollama Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "rate(ollama_requests_total[5m])",
          "legendFormat": "{{model}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Ollama Memory (RSS)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        {
          "expr": "ollama_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2147483648 },
              { "color": "red", "value": 4294967296 }
            ]
          }
        }
      }
    },
    {
      "title": "Knowledge Base",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "title": "KB Reindex Jobs",
      "type": "timeseries",
